# ── Cricket Trading Intelligence System — Environment Variables ──────────────
# Copy to .env locally, or set in Railway Variables panel.

# ── Database (Railway auto-provides DATABASE_URL) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://cricket:cricket123@postgres:5432/cricket_trading
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret

# ── Telegram (REQUIRED for signals) ──────────────────────────────────────────
# 1. Go to https://my.telegram.org/apps → create app → get API_ID + API_HASH
# 2. Run: python tg_step1_request.py  (sends OTP to your phone)
# 3. Run: python tg_step2_login.py    (enter OTP → generates TELEGRAM_SESSION)
TELEGRAM_ENABLED=true
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+91xxxxxxxxxx
TELEGRAM_SESSION=              # StringSession string — paste from tg_step2 output

# Optional: bot for /status /balance /profit commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# Channels to listen for tips (e.g., @ipl_tips,@cricket_calls)
TELEGRAM_CHANNELS=

# ── Gemini AI (REQUIRED for smart analysis) ───────────────────────────────────
# Free key: https://aistudio.google.com/app/apikey  (15 RPM, 1M tokens/day free)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── RoyalBook (for live odds) ─────────────────────────────────────────────────
EXCHANGE_TYPE=simulated        # simulated | royalbook
ROYALBOOK_USERNAME=
ROYALBOOK_PASSWORD=
ROYALBOOK_HEADLESS=true
ROYALBOOK_AUTO_NAVIGATE=true

# ── Trading Agent ─────────────────────────────────────────────────────────────
AGENT_ENABLED=true
AGENT_MODE=simulation          # simulation | live
AGENT_LOOP_INTERVAL=5          # seconds between analysis cycles
AGENT_AUTOPILOT=false          # false = Telegram signals only; true = auto-places bets

# Bankroll & Risk
INITIAL_BANKROLL=10000
MAX_STAKE_PER_TRADE=1000
MAX_EXPOSURE=5000
MAX_DAILY_LOSS=2000
MAX_CONSECUTIVE_LOSSES=5
STOP_LOSS_PCT=20
MAX_DRAWDOWN_PCT=30

# Strategy Thresholds
ODDS_DROP_THRESHOLD=0.15
WIN_PROB_THRESHOLD=0.65
MOMENTUM_THRESHOLD=0.70
MIN_STAKE=100
MAX_STAKE=10000

# ── Cricket Data ──────────────────────────────────────────────────────────────
CRICKET_API_KEY=               # https://cricapi.com — free 100 calls/day
MATCH_POLL_INTERVAL=10
ODDS_SCRAPE_INTERVAL=5
WEATHER_API_KEY=               # OpenWeatherMap — optional, for DLS

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=/app/ml_model/artifacts/xgboost_model.pkl
FEATURE_SCALER_PATH=/app/ml_model/artifacts/scaler.pkl

# ── Groq (fallback AI, optional — Gemini is primary) ─────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
