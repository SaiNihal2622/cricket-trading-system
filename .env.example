# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cricket:cricket123@postgres:5432/cricket_trading
REDIS_URL=redis://redis:6379/0

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret

# ─── Cricket Data ─────────────────────────────────────────────────────────────
# CricAPI: free 100 calls/day at https://cricapi.com (optional — Cricbuzz used by default)
CRICKET_API_KEY=
MATCH_POLL_INTERVAL=10

# ─── Advanced Sure-Shot APIs ──────────────────────────────────────────────────
# OpenWeatherMap for DLS/Rain prediction
WEATHER_API_KEY=
# Betfair API for strict arbitrage
BETFAIR_API_KEY=

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_CHANNELS=

# ─── ML Model ────────────────────────────────────────────────────────────────
MODEL_PATH=/app/ml_model/artifacts/xgboost_model.pkl
FEATURE_SCALER_PATH=/app/ml_model/artifacts/scaler.pkl

# ─── Strategy Thresholds ─────────────────────────────────────────────────────
ODDS_DROP_THRESHOLD=0.15
WIN_PROB_THRESHOLD=0.65
MOMENTUM_THRESHOLD=0.70

# ─── Autonomous Trading Agent ────────────────────────────────────────────────
# Master switch — set to true to enable the autonomous agent
AGENT_ENABLED=false
# "simulation" = paper trading (safe) | "live" = real execution
AGENT_MODE=simulation
# Decision interval in seconds
AGENT_LOOP_INTERVAL=5

# ─── Bankroll & Risk Management ──────────────────────────────────────────────
INITIAL_BANKROLL=10000
MAX_STAKE_PER_TRADE=1000
MAX_EXPOSURE=5000
MAX_DAILY_LOSS=2000
MAX_CONSECUTIVE_LOSSES=5
MAX_DRAWDOWN_PCT=30

# ─── Execution / Exchange ────────────────────────────────────────────────────
# "simulated" = paper trading | "stake" = direct Stake API
EXCHANGE_TYPE=stake
STAKE_API_KEY=
STAKE_GRAPHQL_URL=https://api.stake.com/graphql

# ─── AI Reasoner — Heterogeneous Consensus ───────────────────────────────────
# Primary: MIMO (NVIDIA hosted) — get key at https://build.nvidia.com
MIMO_API_KEY=
MIMO_BASE_URL=https://integrate.api.nvidia.com/v1
MIMO_MODEL=nvidia/mimo-7b

# Secondary: NVIDIA NIM — get key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Tertiary: Gemini — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Quaternary: Groq — get key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Consensus Settings ──────────────────────────────────────────────────────
# Minimum confidence threshold for AI consensus (0-100)
CONSENSUS_THRESHOLD=75
# Require unanimous agreement for ENTER signals
STRICT_CONSENSUS=true

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Enable high-accuracy demo mode with enhanced cricket analytics
DEMO_MODE=true
# Target accuracy for demo predictions (used by ensemble predictor)
DEMO_TARGET_ACCURACY=0.80